# Copy this to .env and fill in your values

# Your Vercel frontend URL (used by backend to generate the QR code join link)
FRONTEND_URL=https://your-app.vercel.app

# Your ngrok backend URL (used by docker-compose to set API_URL for the frontend container)
NGROK_URL=https://your-static-domain.ngrok-free.app

# For Vercel deployments: add API_URL=<your-ngrok-url> in Vercel project env vars
# For local dev: set API_URL=http://localhost:8000 in frontend/.env.local
